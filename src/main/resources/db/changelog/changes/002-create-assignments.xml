<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="002-create-assignments" author="jep21s">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="assignments"/>
            </not>
        </preConditions>

        <createTable tableName="assignments">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_assignments"/>
            </column>
            <column name="order_id" type="UUID"/>
            <column name="volume" type="INT"/>
            <column name="x_coordinate" type="INT"/>
            <column name="y_coordinate" type="INT"/>
            <column name="status" type="VARCHAR(255)"/>
        </createTable>

        <rollback>
            <dropTable tableName="assignments"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
